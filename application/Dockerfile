# Build stage
FROM node:22-alpine AS builder

WORKDIR /app

# Install dependencies first for better layer caching
COPY package*.json ./
RUN npm ci

# Build application
COPY . .

RUN npm run build

# Runtime stage
FROM nginx:1.29-alpine AS runner

# Create required directories and fix permissions (nginx user/group already exists in base image)
RUN mkdir -p /var/cache/nginx/client_temp && \
    mkdir -p /var/run/nginx && \
    mkdir -p /tmp/nginx_client_temp && \
    mkdir -p /tmp/nginx_proxy_temp && \
    chown -R nginx:nginx /var/cache/nginx /var/run/nginx /usr/share/nginx/html /tmp/nginx_*

# Configure nginx to use /tmp for pid and cache directories (non-root / read-only root FS)
RUN sed -i 's|^user  nginx;|# user nginx;|g' /etc/nginx/nginx.conf && \
    sed -i 's|^pid        /run/nginx.pid;|pid /tmp/nginx.pid;|g' /etc/nginx/nginx.conf && \
    sed -i 's|/var/cache/nginx/client_temp|/tmp/nginx_client_temp|g' /etc/nginx/nginx.conf && \
    sed -i 's|/var/cache/nginx/proxy_temp|/tmp/nginx_proxy_temp|g' /etc/nginx/nginx.conf && \
    sed -i 's|/var/cache/nginx/uwsgi_temp|/tmp/nginx_uwsgi_temp|g' /etc/nginx/nginx.conf && \
    sed -i 's|/var/cache/nginx/scgi_temp|/tmp/nginx_scgi_temp|g' /etc/nginx/nginx.conf

# Replace default.conf with a custom one that includes try_files for SPA routing
COPY nginx.default.conf /etc/nginx/conf.d/default.conf

# Copy static assets generated by Vite
COPY --from=builder /app/dist /usr/share/nginx/html
RUN chown -R nginx:nginx /usr/share/nginx/html

EXPOSE 8080

ENTRYPOINT ["nginx", "-g", "daemon off;"]
